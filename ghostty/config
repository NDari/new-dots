# Font
# font-family = JetBrainsMonoNL Nerd Font
font-family = Inconsolata Nerd Font
# font-family = CascadiaMono Nerd Font
# font-family = IosevkaTerm Nerd Font
font-style = Bold
font-style-bold = Bold
font-style-italic = Bold
font-style-bold-italic = Bold
font-size = 12

# Window
window-padding-balance = true
window-decoration = auto
window-theme = dark
window-height = 50
window-width = 200

# Colors (Gruvbox dark)
# theme = Gruvbox Dark Hard
config-file = ?~/.config/ghostty/themes/current
# theme = Catppuccin Frappe

# Cursor
cursor-style = bar
cursor-style-blink = false
cursor-opacity = 1.0

# Scrolling
scrollback-limit = 50000
mouse-scroll-multiplier = 3

# Mouse
mouse-hide-while-typing = true
copy-on-select = true

# Keybinds, general
keybind = shift+enter=text:\x1b\x0d

# nav
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top

# Tmux-like Keybindings (Prefix: alt+S)
# New window (Ghostty uses tabs for windows)
keybind = alt+s>c=new_tab

# Split panes
# '\' for horizontal split (side-by-side)
keybind = alt+s>\=new_split:right
# '-' for vertical split (top and bottom)
keybind = alt+s>-=new_split:down

# Reload Ghostty configuration
keybind = alt+s>r=reload_config

# Optional: Toggle split zoom (Tmux default is Prefix + z)
keybind = alt+s>z=toggle_split_zoom

# Optional: Close the current split or tab (Tmux default is Prefix + x)
keybind = alt+s>x=close_surface
